# ==============================
# .gitignore para ProyectoSistemaInteligente (ASP.NET Core / .NET 8)
# ==============================

# Carpetas de compilación
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/

# Archivos y carpetas de Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Librerías de frontend gestionadas por LibMan (bootstrap, jquery, etc.)
# Se restauran automáticamente al abrir el proyecto o con "libman restore"
wwwroot/lib/

# Archivos subidos por los usuarios en tiempo de ejecución
wwwroot/uploads/

# Configuración local / secretos (descomentar si agregás cadenas de conexión o claves)
# appsettings.Development.json
# appsettings.*.json
# !appsettings.json
# appsettings.*.local.json

# Archivos temporales / generados por .NET
*.dll
*.pdb
*.cache
*.log

# Archivos de sistema operativo
.DS_Store
Thumbs.db

# NuGet
*.nupkg
**/packages/*
!**/packages/build/
project.lock.json
project.fragment.lock.json
artifacts/
